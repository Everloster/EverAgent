#!/bin/sh
# EverAgent pre-commit hook: validate workspace metadata before commit
# Runs validate_workspace.py and blocks commit if ERROR severity found
#
# Install: cp scripts/hooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

REPO_ROOT="$(git rev-parse --show-toplevel)"
SCRIPT="$REPO_ROOT/scripts/validate_workspace.py"

if [ ! -f "$SCRIPT" ]; then
    echo "[pre-commit] validate_workspace.py not found, skipping"
    exit 0
fi

echo "[pre-commit] Running workspace validation..."
OUTPUT=$(python3 "$SCRIPT" 2>&1)
EXIT_CODE=$?

if [ $EXIT_CODE -ne 0 ]; then
    echo "$OUTPUT"
    echo ""
    echo "[pre-commit] BLOCKED: validation errors found. Fix before committing."
    exit 1
fi

# Show warnings but don't block
if [ -n "$OUTPUT" ] && [ "$OUTPUT" != "Workspace validation passed." ]; then
    echo "$OUTPUT"
    echo ""
    echo "[pre-commit] Warnings found (non-blocking). Proceeding with commit."
fi

exit 0
